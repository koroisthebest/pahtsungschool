<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>TK Pah Tsung – Taman Kanak-Kanak</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500;600&family=Outfit:wght@400;600;700&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --navy: #0d2240;
      --navy-light: #163360;
      --gold: #F5C400;
      --gold-light: #FFD740;
      --white: #ffffff;
      --off-white: #f8f5f0;
      --gray: #6b7280;
      --light-gray: #e5e7eb;
      --font-display: 'Playfair Display', serif;
      --font-body: 'DM Sans', sans-serif;
    }
    html { scroll-behavior: smooth; }
    body { font-family: var(--font-body); color: var(--navy); background: var(--white); overflow-x: hidden; }

    
    /* ── NAVBAR ── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 48px; height: 72px;
      background: rgba(255,255,255,0.97);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(245,196,0,0.2);
      box-shadow: 0 4px 24px rgba(13,34,64,0.08);
    }

    .nav-logo {
      text-decoration: none;
      display: flex;
      align-items: center;
    }

    .nav-logo img {
      height: 44px;
      object-fit: contain;
    }

    .nav-back {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 14px;
      font-weight: 600;
      color: var(--navy);
      text-decoration: none;
      transition: color 0.2s, gap 0.2s;
    }

    .nav-back:hover {
      color: var(--gold);
      gap: 12px;
    }

    .nav-back svg {
      transition: transform 0.2s;
    }

    .nav-back:hover svg {
      transform: translateX(-3px);
    }


    /* JENJANG HERO */
    .jenjang-hero {
      position: relative; min-height: 560px;
      display: flex; align-items: flex-end;
      overflow: hidden; background: var(--navy);
      padding-top: 72px;
    }
    .jenjang-hero-bg {
      position: absolute; inset: 0;
      background: linear-gradient(135deg, #0d2240 0%, #1a3a6b 60%, #0d2240 100%);
    }
    .jenjang-hero-pattern {
      position: absolute; inset: 0; opacity: 0.05;
      background-image: radial-gradient(circle at 2px 2px, var(--gold) 1px, transparent 0);
      background-size: 40px 40px;
    }
    .jenjang-hero-img {
      position: absolute; inset: 0;
      background: url('https://i.ibb.co.com/fz1f8ygx/TK-banner-web.jpg') center/cover no-repeat;
      opacity: 0.22;
    }
    .jenjang-hero-content {
      position: relative; z-index: 2;
      padding: 60px 80px 80px;
      max-width: 1100px; width: 100%;
      animation: fadeUp 0.8s ease both;
    }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(28px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .breadcrumb {
      display: flex; align-items: center; gap: 8px;
      margin-bottom: 24px;
    }
    .breadcrumb a { font-size: 13px; color: rgba(255,255,255,0.5); text-decoration: none; transition: color 0.2s; }
    .breadcrumb a:hover { color: var(--gold); }
    .breadcrumb span { font-size: 13px; color: rgba(255,255,255,0.3); }
    .breadcrumb .current { font-size: 13px; color: var(--gold); font-weight: 500; }
    .jenjang-eyebrow {
      display: inline-block; font-size: 11px; font-weight: 600; letter-spacing: 3px;
      text-transform: uppercase; color: var(--gold); margin-bottom: 16px;
      border: 1px solid rgba(245,196,0,0.4); padding: 5px 14px; border-radius: 20px;
    }
    .jenjang-hero h1 {
      font-family: var(--font-display); font-size: clamp(36px, 5vw, 64px);
      color: var(--white); font-weight: 700; line-height: 1.1;
      letter-spacing: -1px; margin-bottom: 20px;
    }
    .jenjang-hero h1 span { color: var(--gold); }
    .jenjang-hero-desc {
      font-size: 17px; color: rgba(255,255,255,0.65); max-width: 580px;
      line-height: 1.7; font-weight: 300; margin-bottom: 40px;
    }
    .jenjang-meta {
      display: flex; gap: 32px; flex-wrap: wrap;
    }
    .jenjang-meta-item {
      display: flex; align-items: center; gap: 10px;
    }
    .jenjang-meta-item .meta-icon {
      width: 36px; height: 36px; border-radius: 8px;
      background: rgba(245,196,0,0.15); border: 1px solid rgba(245,196,0,0.3);
      display: flex; align-items: center; justify-content: center;
      color: var(--gold);
    }
    .jenjang-meta-item .meta-label { font-size: 11px; color: rgba(255,255,255,0.4); letter-spacing: 1px; text-transform: uppercase; }
    .jenjang-meta-item .meta-val { font-size: 14px; color: var(--white); font-weight: 600; }

    /* JENJANG NAV */
    .jenjang-nav {
      background: var(--off-white); border-bottom: 2px solid var(--light-gray);
      padding: 0 80px; display: flex; gap: 0; overflow-x: auto;
    }
    .jenjang-nav a {
      text-decoration: none; padding: 18px 24px; font-size: 14px; font-weight: 500;
      color: var(--gray); border-bottom: 3px solid transparent; white-space: nowrap;
      transition: color 0.2s, border-color 0.2s;
    }
    .jenjang-nav a:hover { color: var(--navy); }
    .jenjang-nav a.active { color: var(--navy); border-bottom-color: var(--gold); font-weight: 600; }

    /* SECTION */
    .section { padding: 80px 80px; }
    .section-inner { max-width: 1100px; margin: 0 auto; }
    .section-eyebrow {
      font-size: 11px; font-weight: 600; letter-spacing: 3px;
      text-transform: uppercase; color: var(--gold); margin-bottom: 14px; display: block;
    }
    .gold-divider { width: 50px; height: 3px; background: var(--gold); border-radius: 2px; margin-bottom: 20px; }
    .section-title {
      font-family: var(--font-display); font-size: clamp(26px, 3.5vw, 40px);
      font-weight: 700; color: var(--navy); line-height: 1.2;
      letter-spacing: -0.5px; margin-bottom: 20px;
    }
    .section-body { font-size: 16px; color: var(--gray); line-height: 1.8; margin-bottom: 24px; }

    /* VISI MISI */
    .vision-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 32px; margin-top: 48px;
    }
    .vision-card {
      background: var(--navy); border-radius: 14px; padding: 36px;
      position: relative; overflow: hidden;
    }
    .vision-card::before {
      content: ''; position: absolute; top: -40px; right: -40px;
      width: 120px; height: 120px; border-radius: 50%;
      background: rgba(245,196,0,0.06);
    }
    .vision-card-icon {
      width: 48px; height: 48px; background: rgba(245,196,0,0.12);
      border-radius: 10px; display: flex; align-items: center; justify-content: center;
      margin-bottom: 20px; color: var(--gold);
    }
    .vision-card h3 {
      font-family: var(--font-display); font-size: 20px; font-weight: 700;
      color: var(--white); margin-bottom: 14px;
    }
    .vision-card p { font-size: 15px; color: rgba(255,255,255,0.6); line-height: 1.7; }
    .vision-card ul { list-style: none; }
    .vision-card ul li {
      font-size: 14px; color: rgba(255,255,255,0.6); line-height: 1.6;
      padding: 6px 0; border-bottom: 1px solid rgba(255,255,255,0.06);
      display: flex; align-items: flex-start; gap: 10px;
    }
    .vision-card ul li:last-child { border-bottom: none; }
    .vision-card ul li::before {
      content: ''; width: 6px; height: 6px; border-radius: 50%;
      background: var(--gold); flex-shrink: 0; margin-top: 7px;
    }

    /* KURIKULUM */
    .kurikulum-section { background: var(--off-white); }
    .kurikulum-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 48px; }
    .kurikulum-card {
      background: var(--white); border-radius: 12px; padding: 28px;
      box-shadow: 0 2px 16px rgba(13,34,64,0.06);
      transition: transform 0.3s, box-shadow 0.3s;
      border-top: 3px solid var(--gold);
    }
    .kurikulum-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 8px 32px rgba(13,34,64,0.1);
    }
    .kurikulum-card-icon {
      width: 44px; height: 44px; background: rgba(13,34,64,0.06);
      border-radius: 10px; display: flex; align-items: center; justify-content: center;
      margin-bottom: 16px; color: var(--navy);
    }
    .kurikulum-card h4 {
      font-family: var(--font-display); font-size: 17px; font-weight: 700;
      color: var(--navy); margin-bottom: 10px;
    }
    .kurikulum-card p { font-size: 14px; color: var(--gray); line-height: 1.7; }

    /* KEGIATAN / ACTIVITIES */
    .activities-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: center; margin-top: 48px; }
    .activities-img {
      border-radius: 14px; overflow: hidden; position: relative;
    }
    .activities-img img {
      width: 100%; height: 420px; object-fit: cover; display: block;
    }
    .activities-img-badge {
      position: absolute; bottom: -16px; right: -16px;
      background: var(--gold); padding: 18px 22px; border-radius: 10px;
      box-shadow: 0 8px 24px rgba(245,196,0,0.35);
    }
    .activities-img-badge .badge-num {
      font-family: var(--font-display); font-size: 32px; font-weight: 700;
      color: var(--navy); line-height: 1;
    }
    .activities-img-badge .badge-txt { font-size: 11px; color: rgba(13,34,64,0.7); margin-top: 2px; }
    .activities-list { list-style: none; }
    .activities-list li {
      display: flex; align-items: flex-start; gap: 16px;
      padding: 16px 0; border-bottom: 1px solid var(--light-gray);
    }
    .activities-list li:last-child { border-bottom: none; }
    .act-icon {
      width: 40px; height: 40px; border-radius: 10px;
      background: rgba(13,34,64,0.05); display: flex; align-items: center; justify-content: center;
      flex-shrink: 0; color: var(--navy);
    }
    .act-title { font-size: 15px; font-weight: 600; color: var(--navy); margin-bottom: 4px; }
    .act-desc { font-size: 13px; color: var(--gray); line-height: 1.6; }

    /* STATS */
    .stats-row {
      background: var(--navy); padding: 60px 80px;
    }
    .stats-inner {
      max-width: 1100px; margin: 0 auto;
      display: grid; grid-template-columns: repeat(4, 1fr); gap: 32px; text-align: center;
    }
    .stat-item {}
    .stat-number {
      font-family: var(--font-display); font-size: 48px; font-weight: 700;
      color: var(--gold); line-height: 1; margin-bottom: 8px;
    }
    .stat-label { font-size: 13px; color: rgba(255,255,255,0.55); line-height: 1.5; }

    /* CTA */
    .cta-section {
      background: linear-gradient(135deg, var(--navy) 0%, var(--navy-light) 100%);
      padding: 80px 80px; text-align: center;
    }
    .cta-section h2 {
      font-family: var(--font-display); font-size: clamp(26px, 4vw, 44px);
      color: var(--white); font-weight: 700; letter-spacing: -0.5px; margin-bottom: 14px;
    }
    .cta-section h2 span { color: var(--gold); }
    .cta-section p { font-size: 16px; color: rgba(255,255,255,0.6); max-width: 460px; margin: 0 auto 36px; line-height: 1.7; }
    .cta-buttons { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
    .btn-primary {
      background: var(--gold); color: var(--navy); padding: 14px 32px;
      border-radius: 6px; font-size: 15px; font-weight: 600; text-decoration: none;
      transition: background 0.2s, transform 0.2s;
    }
    .btn-primary:hover { background: var(--gold-light); transform: translateY(-2px); }
    .btn-outline {
      background: transparent; color: var(--white); border: 2px solid rgba(255,255,255,0.4);
      padding: 14px 32px; border-radius: 6px; font-size: 15px; font-weight: 500;
      text-decoration: none; transition: border-color 0.2s, background 0.2s;
    }
    .btn-outline:hover { border-color: var(--white); background: rgba(255,255,255,0.08); }

    /* OTHER LEVELS */
    .other-levels { background: var(--off-white); }
    .other-levels-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 40px; }
    .other-card {
      background: var(--navy); border-radius: 12px; overflow: hidden;
      text-decoration: none; transition: transform 0.3s;
    }
    .other-card:hover { transform: translateY(-4px); }
    .other-card img { width: 100%; height: 160px; object-fit: cover; display: block; opacity: 0.7; }
    .other-card-body { padding: 20px; }
    .other-card-grade { font-size: 10px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; color: var(--gold); margin-bottom: 6px; display: block; }
    .other-card h4 { font-family: var(--font-display); font-size: 17px; font-weight: 700; color: var(--white); margin-bottom: 6px; }
    .other-card p { font-size: 13px; color: rgba(255,255,255,0.5); line-height: 1.5; }

    /* FOOTER */
    footer { background: #08192e; padding: 60px 80px 32px; }
    .footer-grid {
      max-width: 1100px; margin: 0 auto;
      display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 48px;
      padding-bottom: 48px; border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    .footer-logo { display: flex; align-items: center; gap: 10px; margin-bottom: 16px; }
    .footer-logo img { height: 42px; object-fit: contain; filter: brightness(0) invert(1); opacity: 0.95; }
    .footer-desc { font-size: 14px; color: rgba(255,255,255,0.4); line-height: 1.7; max-width: 260px; }
    .footer-col h5 { font-size: 11px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; color: var(--gold); margin-bottom: 16px; }
    .footer-col ul { list-style: none; }
    .footer-col ul li { margin-bottom: 10px; }
    .footer-col ul li a { text-decoration: none; font-size: 14px; color: rgba(255,255,255,0.5); transition: color 0.2s; }
    .footer-col ul li a:hover { color: var(--white); }
    .footer-bottom {
      max-width: 1100px; margin: 0 auto; padding-top: 28px;
      display: flex; justify-content: space-between; align-items: center;
      font-size: 13px; color: rgba(255,255,255,0.3); flex-wrap: wrap; gap: 12px;
    }

    @media (max-width: 960px) {
      nav { padding: 0 24px; }
      .nav-links { display: none; }
      .jenjang-hero-content { padding: 40px 24px 60px; }
      .section { padding: 60px 24px; }
      .vision-grid, .kurikulum-grid, .activities-grid, .stats-inner, .other-levels-grid { grid-template-columns: 1fr; }
      .jenjang-nav { padding: 0 24px; }
      .stats-row { padding: 48px 24px; }
      .cta-section { padding: 60px 24px; }
      footer { padding: 48px 24px 24px; }
      .footer-grid { grid-template-columns: 1fr 1fr; }
    }
  </style>
</head>
